  "scripts": {
    "start": "nx serve portal --host 0.0.0.0",
    "serve:portal": "nx serve portal --host 0.0.0.0",
    "build": "node tools/generate-runtime-config.mjs && nx build portal",
    "build:portal": "node tools/generate-runtime-config.mjs && nx build portal",
    "build:production": "node tools/generate-runtime-config.mjs && nx build portal --configuration=production",
    "test:unit": "vitest run apps/portal/src/app/core/utils",
    "ci": "npm run test:unit && npm run build:production && npm audit --omit=dev",
    "nx:graph": "nx graph"
  },
