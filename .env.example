# Public runtime configuration. Do not add SUPABASE_SERVICE_ROLE_KEY here or to the frontend.
VIAJES_SUPABASE_URL=https://your-project.supabase.co
VIAJES_SUPABASE_ANON_KEY=your-anon-key

# Edge Function only. Define these as Supabase secrets; never expose them to Angular or Vercel public variables.
TURNSTILE_SECRET_KEY=your-turnstile-secret
LEAD_ALLOWED_ORIGINS=https://your-domain.example
LEAD_DEFAULT_TENANT_SLUG=viajes-cuba-demo
LEAD_IP_HASH_SALT=rotate-this-server-secret
